@model VinfastWeb.Models.AdminProduct
@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="admin-page">
    <div class="admin-shell">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <div>
                    <div class="admin-badge">THÊM MỚI</div>
                    <h1 class="admin-title admin-title-sm">Tạo sản phẩm mới</h1>
                    <p class="admin-subtitle">Nhập thông tin sản phẩm xe máy, ô tô hoặc phụ kiện.</p>
                </div>

                <div class="admin-head-actions">
                    <a asp-action="Index" class="admin-btn admin-btn-light">Quay lại danh sách</a>
                </div>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="admin-alert admin-alert-error" style="margin-bottom:20px;">
                    @TempData["Error"]
                </div>
            }

            <div asp-validation-summary="All" class="text-danger" style="margin-bottom:15px;"></div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="admin-form-grid">
                    <div class="admin-form-section">
                        <h3>Thông tin cơ bản</h3>

                        <div class="admin-field">
                            <label asp-for="ProductName">Tên sản phẩm <span class="required">*</span></label>
                            <input asp-for="ProductName" placeholder="Nhập tên sản phẩm" />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label asp-for="Description">Mô tả</label>
                            <textarea asp-for="Description" rows="6" placeholder="Nhập mô tả sản phẩm"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label>Ảnh sản phẩm</label>

                            <div class="admin-preview-box" id="previewBox" style="display:none;">
                                <div class="admin-preview-label">Xem trước ảnh</div>
                                <img id="previewImg" src="" alt="" class="admin-preview-image" />
                            </div>

                            <div class="admin-upload-group">
                                <label class="admin-upload-label" for="ImageFile">
                                    📁 Chọn ảnh từ máy tính
                                </label>
                                <input type="file"
                                       id="ImageFile"
                                       name="ImageFile"
                                       accept="image/*"
                                       class="admin-upload-input" />
                                <p class="admin-field-hint">Không bắt buộc. Chấp nhận: JPG, PNG, WEBP, GIF.</p>
                            </div>

                            <div class="admin-field" style="margin-top: 0.5rem;">
                                <label asp-for="PathImage">Hoặc nhập đường dẫn ảnh thủ công</label>
                                <input asp-for="PathImage" placeholder="/images/xe.jpg hoặc https://..." />
                                <span asp-validation-for="PathImage" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="admin-form-section">
                        <h3>Phân loại & giá</h3>

                        <div class="admin-field">
                            <label asp-for="ProductType">Loại sản phẩm <span class="required">*</span></label>
                            <select asp-for="ProductType" id="productTypeSelect">
                                <option value="">-- Chọn loại --</option>
                                <option value="Xe máy">Xe máy</option>
                                <option value="Ô tô">Ô tô</option>
                                <option value="Phụ kiện">Phụ kiện</option>
                                <option value="Showroom">Showroom</option>
                            </select>
                            <span asp-validation-for="ProductType" class="text-danger"></span>
                        </div>

                        <div class="admin-field" id="categoryGroupWrapper">
                            <label asp-for="CategoryGroup">Nhóm danh mục</label>
                            <select asp-for="CategoryGroup">
                                <option value="">-- Chọn nhóm danh mục --</option>
                                <option value="pho_thong">Phổ thông</option>
                                <option value="trung_cap">Trung cấp</option>
                                <option value="cao_cap">Cao cấp</option>
                            </select>
                            <span asp-validation-for="CategoryGroup" class="text-danger"></span>
                        </div>

                        <div class="admin-form-row-2">
                            <div class="admin-field">
                                <label asp-for="Quantity">Số lượng</label>
                                <input asp-for="Quantity" type="number" min="0" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>

                            <div class="admin-field">
                                <label asp-for="Unit">Đơn vị</label>
                                <input asp-for="Unit" placeholder="chiếc" />
                                <span asp-validation-for="Unit" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="admin-field">
                            <label asp-for="Price">Giá (VNĐ)</label>
                            <input asp-for="Price"
                                   type="number"
                                   class="form-control" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="admin-form-row-2">
                            <div class="admin-field">
                                <label asp-for="CreateDate">Ngày tạo</label>
                                <input asp-for="CreateDate" type="date" />                                
                                <span asp-validation-for="CreateDate" class="text-danger"></span>
                            </div>

                            <div class="admin-field">
                                <label asp-for="UpdateDate">Ngày sửa</label>
                                <input asp-for="UpdateDate" type="date" />
                                <span asp-validation-for="UpdateDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="admin-form-footer">
                    <a asp-action="Index" class="admin-btn admin-btn-light">Hủy</a>
                    <button type="submit" class="admin-btn admin-btn-primary">Lưu sản phẩm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('ImageFile')?.addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function (e) {
                const box = document.getElementById('previewBox');
                const img = document.getElementById('previewImg');

                if (box) box.style.display = 'block';
                if (img) {
                    img.src = e.target.result;
                    img.alt = file.name;
                }

                const pathInput = document.querySelector('input[name="PathImage"]');
                if (pathInput) pathInput.value = '';
            };
            reader.readAsDataURL(file);
        });

        document.addEventListener("DOMContentLoaded", function () {
            const productTypeSelect = document.getElementById("productTypeSelect");
            const categoryGroupWrapper = document.getElementById("categoryGroupWrapper");
            const categoryGroupSelect = document.querySelector('[name="CategoryGroup"]');

            function toggleCategoryGroup() {
                const value = productTypeSelect.value?.trim().toLowerCase();
                if (value === "xe máy") {
                    categoryGroupWrapper.style.display = "block";
                } else {
                    categoryGroupWrapper.style.display = "none";
                    if (categoryGroupSelect) categoryGroupSelect.value = "";
                }
            }

            toggleCategoryGroup();
            productTypeSelect.addEventListener("change", toggleCategoryGroup);
        });
    </script>
}