@model VinfastWeb.ViewModels.CarsViewModel
@{
    ViewData["Title"] = Model.CategoryLabel;
}

<div class="pd-header">
    <div class="container">
        <nav class="pd-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="fas fa-chevron-right"></i>
            <a href="/Cars">Ô Tô VinFast</a>
            @if (!string.IsNullOrEmpty(Model.Category))
            {
                <i class="fas fa-chevron-right"></i>
                <span>@Model.CategoryLabel</span>
            }
        </nav>
        <h1 class="pd-header-title">@Model.CategoryLabel</h1>
        <p class="pd-header-sub">@Model.Cars.Count mẫu xe đang có sẵn</p>
    </div>
</div>

<div class="pd-filter-bar">
    <div class="container">
        <div class="pd-filter-tabs">
            <a href="/Cars" class="pd-ftab @(string.IsNullOrEmpty(Model.Category) ? "active" : "")">
                Tất Cả
            </a>
            <a href="/Cars?category=dong_co_dien" class="pd-ftab @(Model.Category == "dong_co_dien" ? "active" : "")">
                <i class="fas fa-charging-station"></i> Xe Điện
            </a>
            <a href="/Cars?category=dong_co_xang" class="pd-ftab @(Model.Category == "dong_co_xang" ? "active" : "")">
                <i class="fas fa-gas-pump"></i> Xe Xăng
            </a>
            <a href="/Cars?category=dong_xe_dich_vu" class="pd-ftab @(Model.Category == "dong_xe_dich_vu" ? "active" : "")">
                <i class="fas fa-shuttle-van"></i> Xe Dịch Vụ
            </a>
        </div>
        <div class="pd-sort">
            <select class="pd-sort-select" onchange="sortProducts(this.value)">
                <option value="">Sắp xếp theo</option>
                <option value="price-asc">Giá: Thấp → Cao</option>
                <option value="price-desc">Giá: Cao → Thấp</option>
                <option value="name">Tên A → Z</option>
            </select>
        </div>
    </div>
</div>

<section class="pd-section">
    <div class="container">
        @if (!Model.Cars.Any())
        {
            <div class="pd-empty">
                <i class="fas fa-car"></i>
                <h3>Không có xe nào</h3>
                <p>Vui lòng chọn danh mục khác.</p>
                <a href="/Cars" class="pd-btn-primary">Xem tất cả ô tô</a>
            </div>
        }
        else
        {
            <div class="pd-grid" id="productGrid">
                @foreach (var item in Model.Cars)
                {
                    <div class="pd-card" data-price="@item.Price" data-name="@item.Name">
                        <div class="pd-card-img">
                            <img src="@item.ImageUrl" alt="@item.Name" loading="lazy"
                                 onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 4 3%22%3E%3Crect fill=%22%23f3f4f6%22 width=%224%22 height=%223%22/%3E%3C/svg%3E'" />
                            <div class="pd-card-badge">
                                @(item.Category == "dong_co_dien" ? "Xe Điện" :
                                                        item.Category == "dong_co_xang" ? "Xe Xăng" : "Dịch Vụ")
                    </div>
                    <div class="pd-card-wish"><i class="far fa-heart"></i></div>
                </div>

                        <div class="pd-card-body">
                            <div class="pd-card-cat">VinFast · Ô Tô</div>
                            <div class="pd-card-name">@item.Name</div>

                            <div class="pd-card-specs">
                        @if (item.Category == "dong_co_dien")
                                {
                                    <span><i class="fas fa-charging-station"></i> Điện</span>
                                    <span><i class="fas fa-battery-full"></i> Pin LFP</span>
                                }
                                else
                                {
                                    <span><i class="fas fa-gas-pump"></i> Xăng</span>
                                    <span><i class="fas fa-cog"></i> Động cơ</span>
                                }
                                <span><i class="fas fa-shield-alt"></i> BH 3 năm</span>
                            </div>

                            <div class="pd-card-footer">
                                <div class="pd-card-price">@item.FormattedPrice</div>

                                <a asp-controller="Cars"
                                   asp-action="Detail"
                                   asp-route-id="@item.Id"
                                   class="pd-card-btn">
                                    Xem chi tiết <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        function sortProducts(val) {
          const grid = document.getElementById('productGrid');
          if (!grid) return;
          const cards = Array.from(grid.querySelectorAll('.pd-card'));
          cards.sort((a, b) => {
            if (val === 'price-asc')  return +a.dataset.price - +b.dataset.price;
            if (val === 'price-desc') return +b.dataset.price - +a.dataset.price;
            if (val === 'name')       return a.dataset.name.localeCompare(b.dataset.name);
            return 0;
          });
          cards.forEach(c => grid.appendChild(c));
        }
    </script>
}
