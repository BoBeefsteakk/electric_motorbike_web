@model VinfastWeb.Models.Accessory
@{
    ViewData["Title"] = Model.Name;

    var colors = new[] {
        new { Name = "Đen", Hex = "#111827", Border = "#111827" },
        new { Name = "Trắng", Hex = "#F5F5F0", Border = "#d1d5db" },
        new { Name = "Xám", Hex = "#6b7280", Border = "#6b7280" },
        new { Name = "Xanh", Hex = "#2563eb", Border = "#2563eb" },
    };

    var specs = new[] {
        ("Chính hãng", "VinFast"),
        ("Bảo hành", "Hỗ trợ"),
        ("Tương thích", "Nhiều mẫu xe")
    };
}

<div class="dt-breadcrumb-bar">
    <div class="container">
        <nav class="pd-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="fas fa-chevron-right"></i>
            <a href="/Accessories">Phụ kiện</a>
            <i class="fas fa-chevron-right"></i>
            <span>@Model.Name</span>
        </nav>
    </div>
</div>

<section class="dt-section">
    <div class="container">
        <div class="dt-layout">

            <div class="dt-left">
                <div class="dt-img-main">
                    <img src="@Model.ImageUrl" alt="@Model.Name" id="mainImg"
                         onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 4 3%22%3E%3Crect fill=%22%23f3f4f6%22 width=%224%22 height=%223%22/%3E%3C/svg%3E'" />
                </div>

                <div class="dt-thumbnails">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="dt-thumb @(i == 0 ? "active" : "")" onclick="selectThumb(this)">
                            <img src="@Model.ImageUrl" alt="@Model.Name thumb @(i + 1)" />
                        </div>
                    }
                </div>
            </div>

            <div class="dt-right">

                <div class="dt-tag">Phụ Kiện Chính Hãng</div>

                <h1 class="dt-name">@Model.Name</h1>

                <div class="dt-rating">
                    <div class="dt-stars">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                        <i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                    </div>
                    <span class="dt-rating-num">4.6</span>
                    <span class="dt-rating-count">(198 đánh giá)</span>
                    <span class="dt-divider">|</span>
                    <span class="dt-stock"><i class="fas fa-check-circle"></i> Còn hàng</span>
                </div>

                <div class="dt-price-wrap">
                    <div class="dt-price">@Model.FormattedPrice</div>
                    <div class="dt-price-note">Giá niêm yết phụ kiện chính hãng VinFast</div>
                </div>

                <p class="dt-desc">
                    @Model.Name là phụ kiện chính hãng VinFast, được thiết kế để tối ưu trải nghiệm sử dụng,
                    tăng tính thẩm mỹ và độ tiện nghi cho xe.
                </p>

                <div class="dt-specs-row">
                    @foreach (var spec in specs)
                    {
                        <div class="dt-spec-box">
                            <div class="dt-spec-val">@spec.Item1</div>
                            <div class="dt-spec-label">@spec.Item2</div>
                        </div>
                    }
                </div>

                <div class="dt-option-group">
                    <div class="dt-option-label">
                        Màu sắc: <strong id="colorName">@colors[0].Name</strong>
                    </div>
                    <div class="dt-color-list">
                        @for (int i = 0; i < colors.Length; i++)
                        {
                            var c = colors[i];
                            <button class="dt-color-btn @(i == 0 ? "active" : "")"
                                    style="background:@c.Hex;border-color:@c.Border"
                                    onclick="selectColor(this, '@c.Name')"
                                    title="@c.Name">
                            </button>
                        }
                    </div>
                </div>

                <div class="dt-option-group">
                    <div class="dt-option-label">Số lượng</div>
                    <div class="dt-qty-wrap">
                        <button class="dt-qty-btn" onclick="changeQty(-1)"><i class="fas fa-minus"></i></button>
                        <span class="dt-qty-val" id="qtyVal">1</span>
                        <button class="dt-qty-btn" onclick="changeQty(1)"><i class="fas fa-plus"></i></button>
                    </div>
                </div>

                <div class="dt-actions">
                    <button class="dt-btn-cart" onclick="addToCartDetail()">
                        <i class="fas fa-shopping-bag"></i> Thêm vào giỏ
                    </button>
                    <button class="dt-btn-buy">
                        <i class="fas fa-tag"></i> Mua ngay
                    </button>
                    <button class="dt-btn-wish" title="Yêu thích">
                        <i class="far fa-heart"></i>
                    </button>
                </div>

                <div class="dt-badges">
                    <div class="dt-badge"><i class="fas fa-undo"></i> Đổi trả 30 ngày</div>
                    <div class="dt-badge"><i class="fas fa-shield-alt"></i> Chính hãng VinFast</div>
                    <div class="dt-badge"><i class="fas fa-truck"></i> Giao hàng toàn quốc</div>
                </div>

                <div class="dt-info-tabs">
                    <div class="dt-info-tab-header">
                        <button class="dt-itab active" onclick="switchTab(this,'tab-features')">Tính Năng</button>
                        <button class="dt-itab" onclick="switchTab(this,'tab-specs')">Thông Số</button>
                        <button class="dt-itab" onclick="switchTab(this,'tab-warranty')">Bảo Hành</button>
                    </div>

                    <div class="dt-itab-content active" id="tab-features">
                        <div class="dt-accordion">
                            <div class="dt-acc-item open">
                                <div class="dt-acc-head" onclick="toggleAcc(this)">
                                    <span>Ưu Điểm Nổi Bật</span>
                                    <i class="fas fa-minus"></i>
                                </div>
                                <div class="dt-acc-body">
                                    <ul class="dt-feature-list">
                                        <li><i class="fas fa-check"></i> Thiết kế đẹp, đồng bộ với xe VinFast</li>
                                        <li><i class="fas fa-check"></i> Chất liệu bền bỉ, sử dụng lâu dài</li>
                                        <li><i class="fas fa-check"></i> Lắp đặt dễ dàng và tiện lợi</li>
                                        <li><i class="fas fa-check"></i> Tăng tính tiện nghi và trải nghiệm sử dụng</li>
                                        <li><i class="fas fa-check"></i> Chính hãng, đảm bảo tương thích tốt</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="dt-acc-item">
                                <div class="dt-acc-head" onclick="toggleAcc(this)">
                                    <span>Tương Thích</span>
                                    <i class="fas fa-plus"></i>
                                </div>
                                <div class="dt-acc-body">
                                    <p>Phụ kiện tương thích với nhiều dòng xe VinFast. Vui lòng liên hệ showroom để được tư vấn chính xác theo mẫu xe của bạn.</p>
                                </div>
                            </div>

                            <div class="dt-acc-item">
                                <div class="dt-acc-head" onclick="toggleAcc(this)">
                                    <span>Chính Sách Giao Hàng</span>
                                    <i class="fas fa-plus"></i>
                                </div>
                                <div class="dt-acc-body">
                                    <p>Giao hàng nhanh toàn quốc, hỗ trợ kiểm tra sản phẩm trước khi nhận.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="dt-itab-content" id="tab-specs">
                        <table class="dt-spec-table">
                            <tr><td>Loại sản phẩm</td><td>Phụ kiện</td></tr>
                            <tr><td>Thương hiệu</td><td>VinFast</td></tr>
                            <tr><td>Tình trạng</td><td>Chính hãng</td></tr>
                            <tr><td>Bảo hành</td><td>Hỗ trợ theo chính sách sản phẩm</td></tr>
                            <tr><td>Màu sắc</td><td>4 tùy chọn</td></tr>
                            <tr><td>Tương thích</td><td>Nhiều dòng xe VinFast</td></tr>
                        </table>
                    </div>

                    <div class="dt-itab-content" id="tab-warranty">
                        <div class="dt-warranty-list">
                            <div class="dt-warranty-item">
                                <div class="dt-warranty-icon"><i class="fas fa-shield-alt"></i></div>
                                <div>
                                    <strong>Chính sách bảo hành chính hãng</strong>
                                    <p>Áp dụng theo loại phụ kiện và chính sách hiện hành của VinFast.</p>
                                </div>
                            </div>
                            <div class="dt-warranty-item">
                                <div class="dt-warranty-icon"><i class="fas fa-tools"></i></div>
                                <div>
                                    <strong>Hỗ trợ lắp đặt</strong>
                                    <p>Hỗ trợ tư vấn và lắp đặt tại showroom hoặc đại lý liên kết.</p>
                                </div>
                            </div>
                            <div class="dt-warranty-item">
                                <div class="dt-warranty-icon"><i class="fas fa-headset"></i></div>
                                <div>
                                    <strong>Hỗ trợ khách hàng</strong>
                                    <p>Liên hệ hotline 1800 599 961 để được tư vấn nhanh chóng.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const productId    = @Model.Id;
        const productName  = '@Model.Name.Replace("'", "\\'")';
        const productPrice = @Model.Price;
        const productImg   = '@Model.Image';
        let qty            = 1;
        let chosenColor    = '@colors[0].Name';

        function changeQty(d) {
          qty = Math.max(1, qty + d);
          document.getElementById('qtyVal').textContent = qty;
        }
        function selectColor(btn, name) {
          document.querySelectorAll('.dt-color-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          chosenColor = name;
          document.getElementById('colorName').textContent = name;
        }
        function selectThumb(el) {
          document.querySelectorAll('.dt-thumb').forEach(t => t.classList.remove('active'));
          el.classList.add('active');
        }
        function addToCartDetail() {
          addToCart(productId, 'accessory', productName + ' - ' + chosenColor, productPrice, productImg);
        }
        function switchTab(btn, tabId) {
          document.querySelectorAll('.dt-itab').forEach(t => t.classList.remove('active'));
          document.querySelectorAll('.dt-itab-content').forEach(t => t.classList.remove('active'));
          btn.classList.add('active');
          document.getElementById(tabId).classList.add('active');
        }
        function toggleAcc(head) {
          const item = head.closest('.dt-acc-item');
          const isOpen = item.classList.contains('open');
          document.querySelectorAll('.dt-acc-item').forEach(i => {
            i.classList.remove('open');
            i.querySelector('i').className = 'fas fa-plus';
          });
          if (!isOpen) {
            item.classList.add('open');
            head.querySelector('i').className = 'fas fa-minus';
          }
        }
    </script>
}