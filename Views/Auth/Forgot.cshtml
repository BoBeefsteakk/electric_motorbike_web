@{
    ViewData["Title"] = "Quên Mật Khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên Mật Khẩu — VinFast</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: 'DM Sans',sans-serif;
            height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            overflow: hidden
        }

        .auth-left {
            position: relative;
            overflow: hidden;
            /* TODO: Thay URL ảnh bằng ảnh xe VinFast thực tế */
            background: url('/api-images/car/Vinfast VF7.jpg') center/cover no-repeat;
        }

        .auth-left-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom,rgba(0,0,0,0.1) 0%,rgba(0,0,0,0.6) 100%)
        }

        .auth-left-content {
            position: absolute;
            bottom: 48px;
            left: 48px;
            right: 48px;
            color: #fff
        }

        .auth-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px
        }

        .auth-brand-icon {
            width: 52px;
            height: 52px;
            background: #fff;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .vf-logo-icon {
            background: #3D5AFE;
            color: #fff;
            font-family: 'Playfair Display',serif;
            font-size: 16px;
            font-weight: 700;
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .auth-brand-name {
            font-family: 'Playfair Display',serif;
            font-size: 26px;
            font-weight: 700;
            color: #fff
        }

        .auth-left-title {
            font-family: 'Playfair Display',serif;
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            line-height: 1.3;
            margin-bottom: 12px
        }

        .auth-left-desc {
            font-size: 14px;
            color: rgba(255,255,255,0.75);
            line-height: 1.7;
            font-weight: 300;
            max-width: 380px
        }

        .auth-right {
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 48px 40px
        }

        .auth-form-box {
            width: 100%;
            max-width: 420px
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13.5px;
            color: #6b7280;
            text-decoration: none;
            margin-bottom: 32px;
            transition: color 0.2s
        }

            .back-link:hover {
                color: #3D5AFE
            }

        .auth-icon-wrap {
            width: 64px;
            height: 64px;
            background: #eef0ff;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            font-size: 26px;
            color: #3D5AFE
        }

        .auth-form-title {
            font-family: 'Playfair Display',serif;
            font-size: 30px;
            font-weight: 700;
            color: #111;
            margin-bottom: 8px
        }

        .auth-form-sub {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 32px;
            font-weight: 300;
            line-height: 1.6
        }

        .auth-field {
            margin-bottom: 20px
        }

        .auth-label {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 0.2px
        }

        .auth-input-wrap {
            position: relative
        }

            .auth-input-wrap i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #9ca3af;
                font-size: 14px;
                pointer-events: none
            }

        .auth-input {
            width: 100%;
            background: #f9fafb;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 13px 14px 13px 44px;
            font-size: 14px;
            color: #111;
            font-family: 'DM Sans',sans-serif;
            outline: none;
            transition: all 0.2s
        }

            .auth-input:focus {
                border-color: #3D5AFE;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(61,90,254,0.08)
            }

            .auth-input::placeholder {
                color: #d1d5db
            }

        .auth-submit {
            width: 100%;
            background: #111;
            color: #fff;
            font-size: 15px;
            font-weight: 600;
            padding: 15px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'DM Sans',sans-serif
        }

            .auth-submit:hover {
                background: #3D5AFE;
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(61,90,254,0.3)
            }

        .auth-bottom {
            text-align: center;
            font-size: 14px;
            color: #6b7280;
            margin-top: 20px
        }

            .auth-bottom a {
                color: #111;
                font-weight: 700;
                text-decoration: none
            }

                .auth-bottom a:hover {
                    color: #3D5AFE
                }

        @@media(max-width:768px) {
            body {
                grid-template-columns: 1fr
            }

            .auth-left {
                display: none
            }

            .auth-right {
                padding: 32px 24px
            }
        }
    </style>
</head>
<body>

    <!-- LEFT -->
    <!-- TODO: Thay ảnh nền bằng ảnh VinFast thực tế -->
    <div class="auth-left">
        <div class="auth-left-overlay"></div>
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="auth-brand-icon">
                    <div class="vf-logo-icon">VF</div>
                </div>
                <span class="auth-brand-name">VinFast</span>
            </div>
            <div class="auth-left-title">Đừng Lo Lắng,<br>Chúng Tôi Sẽ Giúp Bạn</div>
            <p class="auth-left-desc">
                Chỉ cần cung cấp tài khoản đã đăng ký,
                chúng tôi sẽ hướng dẫn bạn đặt lại mật khẩu nhanh chóng.
            </p>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="auth-form-box">

            <a href="/Auth/Login" class="back-link">
                <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
            </a>

            <div class="auth-icon-wrap">
                <i class="fas fa-key"></i>
            </div>

            <h1 class="auth-form-title">Quên Mật Khẩu?</h1>
            <p class="auth-form-sub">
                Nhập tài khoản của bạn bên dưới. Chúng tôi sẽ liên hệ hỗ trợ bạn đặt lại mật khẩu.
            </p>

            <form method="post">
                <div class="auth-field">
                    <label class="auth-label">Tài khoản</label>
                    <div class="auth-input-wrap">
                        <i class="fas fa-user"></i>
                        <input type="text" name="Account" class="auth-input"
                               placeholder="Nhập tài khoản đã đăng ký" />
                    </div>
                </div>
                <button type="submit" class="auth-submit">Gửi Yêu Cầu</button>
            </form>

            <div class="auth-bottom">
                Nhớ mật khẩu rồi? <a href="/Auth/Login">Đăng nhập</a>
            </div>

        </div>
    </div>

</body>
</html>
