@model VinfastWeb.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng Ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Ký — VinFast</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: 'DM Sans',sans-serif;
            height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            overflow: hidden
        }

        .auth-left {
            position: relative;
            overflow: hidden;
            /* TODO: Thay URL ảnh bên dưới bằng ảnh xe VinFast thực tế */
            background: url('/api-images/motorbike/VinFast Feliz S.jpg') center/cover no-repeat;
        }

        .auth-left-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom,rgba(0,0,0,0.1) 0%,rgba(0,0,0,0.6) 100%)
        }

        .auth-left-content {
            position: absolute;
            bottom: 48px;
            left: 48px;
            right: 48px;
            color: #fff
        }

        .auth-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px
        }

        .auth-brand-icon {
            width: 52px;
            height: 52px;
            background: #fff;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center
        }

            .auth-brand-icon .vf-logo-icon {
                background: #3D5AFE;
                color: #fff;
                font-family: 'Playfair Display',serif;
                font-size: 16px;
                font-weight: 700;
                width: 38px;
                height: 38px;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center
            }

        .auth-brand-name {
            font-family: 'Playfair Display',serif;
            font-size: 26px;
            font-weight: 700;
            color: #fff
        }

        .auth-left-title {
            font-family: 'Playfair Display',serif;
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            line-height: 1.3;
            margin-bottom: 12px
        }

        .auth-left-desc {
            font-size: 14px;
            color: rgba(255,255,255,0.75);
            line-height: 1.7;
            font-weight: 300;
            max-width: 380px
        }

        .auth-right {
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 48px 40px;
            overflow-y: auto
        }

        .auth-form-box {
            width: 100%;
            max-width: 420px
        }

        .auth-form-title {
            font-family: 'Playfair Display',serif;
            font-size: 32px;
            font-weight: 700;
            color: #111;
            margin-bottom: 6px
        }

        .auth-form-sub {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 32px;
            font-weight: 300
        }

        .auth-alert {
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13.5px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px
        }

            .auth-alert.error {
                background: #fff5f5;
                border: 1px solid #fecaca;
                color: #dc2626
            }

            .auth-alert.success {
                background: #f0fdf4;
                border: 1px solid #bbf7d0;
                color: #16a34a
            }

        .auth-field {
            margin-bottom: 18px
        }

        .auth-label {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
            letter-spacing: 0.2px
        }

        .auth-input-wrap {
            position: relative
        }

            .auth-input-wrap i.icon-left {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #9ca3af;
                font-size: 14px;
                pointer-events: none
            }

        .auth-input {
            width: 100%;
            background: #f9fafb;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 13px 44px;
            font-size: 14px;
            color: #111;
            font-family: 'DM Sans',sans-serif;
            outline: none;
            transition: all 0.2s
        }

            .auth-input:focus {
                border-color: #3D5AFE;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(61,90,254,0.08)
            }

            .auth-input::placeholder {
                color: #d1d5db
            }

        .btn-eye {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 14px;
            cursor: pointer;
            background: none;
            border: none;
            transition: color 0.2s
        }

            .btn-eye:hover {
                color: #3D5AFE
            }

        .auth-submit {
            width: 100%;
            background: #111;
            color: #fff;
            font-size: 15px;
            font-weight: 600;
            padding: 15px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'DM Sans',sans-serif;
            letter-spacing: 0.3px
        }

            .auth-submit:hover {
                background: #3D5AFE;
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(61,90,254,0.3)
            }

        .auth-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
            color: #9ca3af;
            font-size: 11.5px;
            letter-spacing: 1.5px;
            text-transform: uppercase
        }

            .auth-divider::before, .auth-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e5e7eb
            }

        .auth-social {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 24px
        }

        .auth-social-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 11px 16px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            color: #374151;
            background: #fff;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'DM Sans',sans-serif;
            text-decoration: none
        }

            .auth-social-btn:hover {
                border-color: #3D5AFE;
                color: #3D5AFE;
                background: #f5f7ff
            }

        .auth-bottom {
            text-align: center;
            font-size: 14px;
            color: #6b7280;
            margin-top: 8px
        }

            .auth-bottom a {
                color: #111;
                font-weight: 700;
                text-decoration: none
            }

                .auth-bottom a:hover {
                    color: #3D5AFE
                }

        .auth-terms {
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
            margin-top: 24px;
            line-height: 1.6
        }

            .auth-terms a {
                color: #6b7280;
                text-decoration: underline
            }

        .password-strength {
            margin-top: 6px;
            height: 4px;
            border-radius: 2px;
            background: #e5e7eb;
            overflow: hidden
        }

        .password-strength-bar {
            height: 100%;
            width: 0;
            border-radius: 2px;
            transition: all 0.3s
        }

        @@media(max-width:768px) {
            body {
                grid-template-columns: 1fr
            }

            .auth-left {
                display: none
            }

            .auth-right {
                padding: 32px 24px
            }
        }
    </style>
</head>
<body>

    <!-- LEFT -->
    <!-- TODO: Thay ảnh nền .auth-left bằng ảnh VinFast thực tế -->
    <div class="auth-left">
        <div class="auth-left-overlay"></div>
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="auth-brand-icon">
                    <div class="vf-logo-icon">VF</div>
                </div>
                <span class="auth-brand-name">VinFast</span>
            </div>
            <div class="auth-left-title">Tham Gia Cùng<br>Hàng Ngàn Khách Hàng</div>
            <p class="auth-left-desc">
                Tạo tài khoản ngay để nhận ưu đãi độc quyền, theo dõi đơn hàng
                và trải nghiệm dịch vụ VinFast tốt nhất.
            </p>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="auth-form-box">

            <h1 class="auth-form-title">Tạo Tài Khoản</h1>
            <p class="auth-form-sub">Đăng ký miễn phí, nhận ngay ưu đãi chào mừng</p>

            @if (Model.ErrorMessage != null)
            {
                <div class="auth-alert error">
                    <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
                </div>
            }

            <form method="post" asp-action="Register" asp-controller="Auth">

                <div class="auth-field">
                    <div class="auth-label"><span>Tên tài khoản</span></div>
                    <div class="auth-input-wrap">
                        <i class="fas fa-user icon-left"></i>
                        <input type="text" name="Account" class="auth-input"
                               placeholder="Nhập tên tài khoản"
                               value="@Model.Account" autocomplete="username" />
                    </div>
                </div>

                <div class="auth-field">
                    <div class="auth-label"><span>Mật khẩu</span></div>
                    <div class="auth-input-wrap">
                        <i class="fas fa-lock icon-left"></i>
                        <input type="password" name="Password" id="pw1" class="auth-input"
                               placeholder="Tạo mật khẩu (tối thiểu 6 ký tự)"
                               autocomplete="new-password"
                               oninput="checkStrength(this.value)" />
                        <button type="button" class="btn-eye" onclick="togglePw('pw1','eye1')">
                            <i class="fas fa-eye" id="eye1"></i>
                        </button>
                    </div>
                    <div class="password-strength">
                        <div class="password-strength-bar" id="strengthBar"></div>
                    </div>
                </div>

                <div class="auth-field">
                    <div class="auth-label"><span>Xác nhận mật khẩu</span></div>
                    <div class="auth-input-wrap">
                        <i class="fas fa-lock icon-left"></i>
                        <input type="password" name="ConfirmPassword" id="pw2" class="auth-input"
                               placeholder="Nhập lại mật khẩu"
                               autocomplete="new-password" />
                        <button type="button" class="btn-eye" onclick="togglePw('pw2','eye2')">
                            <i class="fas fa-eye" id="eye2"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="auth-submit">Đăng Ký Ngay</button>
            </form>

            <div class="auth-divider">Hoặc tiếp tục với</div>

            <div class="auth-social">
                <a href="#" class="auth-social-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" /><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" /><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84z" /></svg>
                    Google
                </a>
                <a href="#" class="auth-social-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#1877F2" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
                    Facebook
                </a>
            </div>

            <div class="auth-bottom">
                Đã có tài khoản? <a href="/Auth/Login">Đăng nhập ngay</a>
            </div>

            <div class="auth-terms">
                Bằng cách đăng ký, bạn đồng ý với
                <a href="#">Điều Khoản & Điều Kiện</a> và
                <a href="#">Chính Sách Bảo Mật</a> của chúng tôi
            </div>

        </div>
    </div>

    <script>
        function togglePw(id, iconId) {
          const input = document.getElementById(id);
          const icon  = document.getElementById(iconId);
          input.type  = input.type === 'password' ? 'text' : 'password';
          icon.className = input.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
        }
        function checkStrength(val) {
          const bar = document.getElementById('strengthBar');
          let score = 0;
          if (val.length >= 6)  score++;
          if (val.length >= 10) score++;
          if (/[A-Z]/.test(val)) score++;
          if (/[0-9]/.test(val)) score++;
          if (/[^A-Za-z0-9]/.test(val)) score++;
          const colors = ['','#ef4444','#f97316','#eab308','#22c55e','#16a34a'];
          const widths  = ['0%','20%','40%','60%','80%','100%'];
          bar.style.width      = widths[score];
          bar.style.background = colors[score];
        }
    </script>
</body>
</html>
