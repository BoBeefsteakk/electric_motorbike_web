@model VinfastWeb.ViewModels.CartViewModel

<div class="container my-5">
    <div class="cart-container shadow-sm">
        <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

        <table class="table align-middle">
            <thead class="bg-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th style="width: 100px;">Số lượng</th>
                    <th>Tổng</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="cartTable">
                @foreach (var item in Model.Items)
                {
                    <tr data-id="@item.ProductId" data-type="@item.ProductType" class="cart-item-card">
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@item.Image" class="product-img me-3" onerror="this.src='/images/no-image.png'">
                                <div>
                                    <div class="fw-bold">@item.Name</div>
                                    <small class="text-muted">@item.ProductType</small>
                                </div>
                            </div>
                        </td>
                        <td>@item.FormattedPrice</td>
                        <td>
                            <input type="number" value="@item.Quantity" min="1"
                                   class="form-control qty-input text-center" />
                        </td>
                        <td class="item-total fw-bold">@item.FormattedTotal</td>
                        <td>
                            <button class="btn btn-remove shadow-sm">
                                <i class="fas fa-times"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row justify-content-end mt-4">
            <div class="col-md-4">
                <div class="grand-total-box shadow-sm">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính:</span>
                        <span class="fw-bold">@Model.FormattedGrandTotal</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="h5 fw-bold text-uppercase">Tổng cộng:</span>
                        <span id="grandTotal" class="h4 fw-bold text-primary">@Model.FormattedGrandTotal</span>
                    </div>
                    <button class="btn btn-primary w-100 py-3 rounded-pill fw-bold btn-checkout">
                        THANH TOÁN NGAY <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                    <button id="clearCart" class="btn btn-link w-100 text-muted mt-2">Xóa sạch giỏ hàng</button>
                </div>
            </div>
        </div>
    </div>
</div>