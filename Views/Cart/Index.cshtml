@model VinfastWeb.ViewModels.CartViewModel
@using VinfastWeb.Models
@using VinfastWeb.ViewModels

@{
    var cartModel = Model ?? new CartViewModel
    {
        Items = new List<CartItem>()
    };

    cartModel.Items ??= new List<CartItem>();

    ViewData["Title"] = "Giỏ Hàng";
}

<style>
    .cart-page {
        padding: 48px 0 80px;
        min-height: 60vh;
        background: #f8f9fa;
    }

    .cart-page-title {
        font-size: 2rem;
        font-weight: 800;
        color: #111;
        margin-bottom: 8px;
    }

    .cart-page-sub {
        color: #888;
        font-size: 0.95rem;
        margin-bottom: 36px;
    }

    .cart-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,.07);
        overflow: hidden;
        margin-bottom: 24px;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

        .cart-table thead th {
            background: #f8f9fa;
            padding: 14px 20px;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #888;
            border-bottom: 1px solid #f0f0f0;
        }

        .cart-table tbody tr {
            border-bottom: 1px solid #f5f5f5;
            transition: background .15s;
        }

            .cart-table tbody tr:last-child {
                border-bottom: none;
            }

            .cart-table tbody tr:hover {
                background: #fafafa;
            }

        .cart-table td {
            padding: 16px 20px;
            vertical-align: middle;
        }

    .cart-product-wrap {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .cart-product-img {
        width: 72px;
        height: 56px;
        border-radius: 10px;
        object-fit: cover;
        background: #f3f4f6;
        flex-shrink: 0;
    }

    .cart-product-name {
        font-weight: 700;
        color: #111;
        font-size: .95rem;
        margin-bottom: 2px;
    }

    .cart-product-type {
        font-size: .78rem;
        color: #aaa;
        background: #f3f4f6;
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .cart-price {
        font-weight: 600;
        color: #333;
        white-space: nowrap;
    }

    .cart-item-total {
        font-weight: 800;
        color: #1565c0;
        white-space: nowrap;
    }

    .cart-qty-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
        width: 110px;
    }

    .cart-qty-btn {
        width: 28px;
        height: 28px;
        border: 1.5px solid #e0e0e0;
        border-radius: 8px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        color: #555;
        transition: all .15s;
        flex-shrink: 0;
    }

        .cart-qty-btn:hover {
            border-color: #1565c0;
            color: #1565c0;
            background: #e3f2fd;
        }

    .qty-input {
        width: 44px;
        height: 28px;
        border: 1.5px solid #e0e0e0;
        border-radius: 8px;
        text-align: center;
        font-size: .88rem;
        font-weight: 700;
        color: #111;
        outline: none;
        transition: border .15s;
    }

        .qty-input:focus {
            border-color: #1565c0;
        }

    .cart-remove-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1.5px solid #f0f0f0;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #bbb;
        transition: all .2s;
    }

        .cart-remove-btn:hover {
            background: #fce4ec;
            border-color: #e91e63;
            color: #e91e63;
        }

    .cart-summary {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,.07);
        padding: 28px 24px;
        position: sticky;
        top: 90px;
    }

    .cart-summary-title {
        font-size: 1rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 1px solid #f0f0f0;
    }

    .cart-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-size: .92rem;
        color: #555;
    }

        .cart-summary-row.total {
            padding-top: 14px;
            margin-top: 6px;
            border-top: 2px solid #f0f0f0;
            font-size: 1rem;
            color: #111;
            font-weight: 800;
        }

            .cart-summary-row.total .val {
                font-size: 1.3rem;
                color: #1565c0;
                font-weight: 900;
            }

    .cart-checkout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 14px;
        background: #1565c0;
        color: #fff;
        border: none;
        border-radius: 50px;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 20px;
        transition: background .2s, transform .15s;
        text-decoration: none;
    }

        .cart-checkout-btn:hover {
            background: #0d47a1;
            transform: translateY(-1px);
            color: #fff;
        }

    .cart-clear-btn {
        display: block;
        width: 100%;
        background: none;
        border: none;
        color: #bbb;
        font-size: .85rem;
        cursor: pointer;
        text-align: center;
        margin-top: 12px;
        padding: 6px;
        transition: color .15s;
    }

        .cart-clear-btn:hover {
            color: #e91e63;
        }

    .cart-voucher-row {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
    }

    .cart-voucher-input {
        flex: 1;
        height: 38px;
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        padding: 0 12px;
        font-size: .88rem;
        outline: none;
        transition: border .15s;
    }

        .cart-voucher-input:focus {
            border-color: #1565c0;
        }

    .cart-voucher-btn {
        height: 38px;
        padding: 0 14px;
        background: #f3f4f6;
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        color: #555;
        transition: all .15s;
    }

        .cart-voucher-btn:hover {
            background: #e3f2fd;
            border-color: #1565c0;
            color: #1565c0;
        }

    .cart-empty {
        text-align: center;
        padding: 80px 24px;
    }

    .cart-empty-icon {
        font-size: 4rem;
        color: #e0e0e0;
        margin-bottom: 20px;
    }

    .cart-empty h3 {
        font-weight: 800;
        color: #333;
        margin-bottom: 10px;
    }

    .cart-empty p {
        color: #aaa;
        margin-bottom: 28px;
    }

    .cart-breadcrumb {
        font-size: .85rem;
        color: #aaa;
        margin-bottom: 24px;
    }

        .cart-breadcrumb a {
            color: #1565c0;
            text-decoration: none;
        }

            .cart-breadcrumb a:hover {
                text-decoration: underline;
            }

        .cart-breadcrumb span {
            margin: 0 8px;
        }

    .cart-continue-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #1565c0;
        font-size: .88rem;
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 16px;
        transition: gap .15s;
    }

        .cart-continue-link:hover {
            gap: 10px;
            color: #0d47a1;
        }
</style>

<section class="cart-page">
    <div class="container">
        <div class="cart-breadcrumb">
            <a href="/">Trang Chủ</a>
            <span>/</span>
            <strong style="color:#333">Giỏ Hàng</strong>
        </div>

        <h2 class="cart-page-title">Giỏ Hàng Của Bạn</h2>
        <p class="cart-page-sub" id="cartSubText">Đang tải giỏ hàng...</p>

        <div id="cartContent"></div>
    </div>
</section>

@section Scripts {
    <script>
        function formatMoney(value) {
            return (Number(value || 0)).toLocaleString('vi-VN') + ' ₫';
        }

        function applyVoucher() {
            const code = document.getElementById('voucherInput')?.value?.trim()?.toUpperCase();
            if (!code) return;
            alert('Mã "' + code + '" chưa được nhận diện. Vui lòng thử lại!');
        }

        function renderCartPage(items, grandTotal) {
            const cartContent = document.getElementById('cartContent');
            const cartSubText = document.getElementById('cartSubText');

            if (!items || items.length === 0) {
                cartSubText.textContent = 'Giỏ hàng hiện đang trống';

                cartContent.innerHTML = `
                    <div class="cart-card">
                        <div class="cart-empty">
                            <div class="cart-empty-icon"><i class="fas fa-shopping-cart"></i></div>
                            <h3>Giỏ hàng trống</h3>
                            <p>Hãy thêm sản phẩm yêu thích của bạn vào giỏ hàng nhé!</p>
                            <a href="/Products" class="ch-hero-btn-primary" style="display:inline-flex;gap:8px;align-items:center">
                                Khám phá xe ngay <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                `;
                return;
            }

            cartSubText.textContent = `Bạn có ${items.length} sản phẩm trong giỏ hàng`;

            const rowsHtml = items.map(item => {
                const itemTotal = Number(item.price || 0) * Number(item.quantity || 0);

                return `
                    <tr data-id="${item.product_id}" data-type="${item.product_type}" class="cart-row">
                        <td>
                            <div class="cart-product-wrap">
                                <img src="${item.image || '/images/no-image.png'}"
                                     class="cart-product-img"
                                     alt="${item.name || ''}"
                                     onerror="this.src='/images/no-image.png'" />
                                <div>
                                    <div class="cart-product-name">${item.name || ''}</div>
                                    <span class="cart-product-type">${item.product_type || ''}</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="cart-price">${formatMoney(item.price)}</div>
                        </td>
                        <td>
                            <div class="cart-qty-wrap">
                                <button class="cart-qty-btn qty-minus" type="button">
                                    <i class="fas fa-minus" style="font-size:.7rem"></i>
                                </button>
                                <input type="number"
                                       value="${item.quantity}"
                                       min="1"
                                       class="qty-input" />
                                <button class="cart-qty-btn qty-plus" type="button">
                                    <i class="fas fa-plus" style="font-size:.7rem"></i>
                                </button>
                            </div>
                        </td>
                        <td>
                            <div class="cart-item-total item-total">${formatMoney(itemTotal)}</div>
                        </td>
                        <td>
                            <button class="cart-remove-btn btn-remove" type="button" title="Xoá">
                                <i class="fas fa-times" style="font-size:.8rem"></i>
                            </button>
                        </td>
                    </tr>
                `;
            }).join('');

            cartContent.innerHTML = `
                <div class="row g-4">
                    <div class="col-lg-8">
                        <a href="/Products" class="cart-continue-link">
                            <i class="fas fa-arrow-left"></i> Tiếp tục mua sắm
                        </a>

                        <div class="cart-card">
                            <table class="cart-table" id="cartTable">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Giá</th>
                                        <th>Số lượng</th>
                                        <th>Tổng</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${rowsHtml}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="cart-summary">
                            <div class="cart-summary-title">
                                <i class="fas fa-receipt" style="color:#1565c0;margin-right:8px"></i>
                                Tóm Tắt Đơn Hàng
                            </div>

                            <div class="cart-voucher-row">
                                <input type="text" class="cart-voucher-input" placeholder="Nhập mã giảm giá..." id="voucherInput" />
                                <button class="cart-voucher-btn" onclick="applyVoucher()">Áp dụng</button>
                            </div>

                            <div class="cart-summary-row">
                                <span>Tạm tính</span>
                                <span class="fw-bold">${formatMoney(grandTotal)}</span>
                            </div>
                            <div class="cart-summary-row">
                                <span>Phí vận chuyển</span>
                                <span style="color:#388e3c;font-weight:700">Miễn phí</span>
                            </div>
                            <div class="cart-summary-row">
                                <span>Giảm giá</span>
                                <span id="discountVal">— 0 ₫</span>
                            </div>

                            <div class="cart-summary-row total">
                                <span>Tổng cộng</span>
                                <span class="val" id="grandTotal">${formatMoney(grandTotal)}</span>
                            </div>

                            <button type="button" class="cart-checkout-btn btn-checkout">
                                Thanh Toán Ngay <i class="fas fa-arrow-right"></i>
                            </button>

                            <button id="clearCart" class="cart-clear-btn">
                                <i class="fas fa-trash-alt" style="font-size:.8rem;margin-right:4px"></i>
                                Xóa sạch giỏ hàng
                            </button>

                            <div style="display:flex;gap:10px;justify-content:center;margin-top:20px;padding-top:16px;border-top:1px solid #f0f0f0">
                                <div style="text-align:center;font-size:.72rem;color:#aaa">
                                    <i class="fas fa-shield-alt" style="display:block;font-size:1.1rem;color:#388e3c;margin-bottom:4px"></i>
                                    Bảo mật<br>thanh toán
                                </div>
                                <div style="text-align:center;font-size:.72rem;color:#aaa">
                                    <i class="fas fa-undo" style="display:block;font-size:1.1rem;color:#1565c0;margin-bottom:4px"></i>
                                    Đổi trả<br>30 ngày
                                </div>
                                <div style="text-align:center;font-size:.72rem;color:#aaa">
                                    <i class="fas fa-headset" style="display:block;font-size:1.1rem;color:#f57c00;margin-bottom:4px"></i>
                                    Hỗ trợ<br>24/7
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            bindCartEvents();
        }

        function bindCartEvents() {
            document.querySelectorAll('.qty-minus').forEach(btn => {
                btn.addEventListener('click', function () {
                    const row = this.closest('tr');
                    const input = row.querySelector('.qty-input');
                    let qty = parseInt(input.value) || 1;

                    if (qty > 1) {
                        qty -= 1;
                        input.value = qty;
                        updateQty(
                            parseInt(row.dataset.id),
                            row.dataset.type,
                            qty,
                            row
                        );
                    }
                });
            });

            document.querySelectorAll('.qty-plus').forEach(btn => {
                btn.addEventListener('click', function () {
                    const row = this.closest('tr');
                    const input = row.querySelector('.qty-input');
                    let qty = parseInt(input.value) || 1;

                    qty += 1;
                    input.value = qty;
                    updateQty(
                        parseInt(row.dataset.id),
                        row.dataset.type,
                        qty,
                        row
                    );
                });
            });

            document.querySelectorAll('.qty-input').forEach(input => {
                input.addEventListener('change', function () {
                    const row = this.closest('tr');
                    let qty = parseInt(this.value) || 1;
                    if (qty < 1) qty = 1;
                    this.value = qty;

                    updateQty(
                        parseInt(row.dataset.id),
                        row.dataset.type,
                        qty,
                        row
                    );
                });
            });

            document.querySelectorAll('.btn-remove').forEach(btn => {
                btn.addEventListener('click', function () {
                    const row = this.closest('tr');
                    removeItem(
                        parseInt(row.dataset.id),
                        row.dataset.type
                    );
                });
            });
            const btnCheckout = document.querySelector('.btn-checkout');
            if (btnCheckout) {
                btnCheckout.addEventListener('click', async function (e) {
                    e.preventDefault();

                    const result = await Swal.fire({
                        title: 'Xác nhận thanh toán?',
                        text: "Đơn hàng của bạn sẽ được xử lý ngay lập tức!",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#1a1a1a',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Đồng ý',
                        cancelButtonText: 'Hủy'
                    });

                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Đang xử lý...',
                            didOpen: () => { Swal.showLoading(); },
                            allowOutsideClick: false
                        });

                        try {
                            const userId = window.currentUserId;

                            const response = await fetch('http://localhost:5000/api/order/checkout', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    user_id: userId
                                })
                            });

                            const data = await response.json();

                            if (data.success) {
                                const cartTable = document.getElementById('cartTable');
                                if (cartTable) cartTable.innerHTML = '';

                                const grandTotal = document.getElementById('grandTotal');
                                if (grandTotal) grandTotal.innerText = '0 ₫';

                                const cartBadge = document.getElementById('cartBadge');
                                if (cartBadge) {
                                    cartBadge.innerText = '0';
                                    cartBadge.style.display = 'none';
                                }

                                await Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công!',
                                    text: `Đơn hàng ${data.order_id} đã được tạo.`,
                                    timer: 1500,
                                    showConfirmButton: false
                                });

                                window.location.href = '/Order/Success';
                            } else {
                                Swal.fire('Lỗi!', data.message || 'Không thể checkout.', 'error');
                            }
                        } catch (error) {
                            console.error('Checkout Error:', error);
                            Swal.fire('Thất bại!', 'Không thể kết nối đến máy chủ.', 'error');
                        }
                    }
                });
            }
        }

        async function loadCartPage() {
            try {
                const userId = window.currentUserId;
                const cartContent = document.getElementById('cartContent');
                const cartSubText = document.getElementById('cartSubText');

                if (!userId) {
                    cartSubText.textContent = 'Bạn cần đăng nhập để xem giỏ hàng';
                    cartContent.innerHTML = `
                        <div class="cart-card">
                            <div class="cart-empty">
                                <div class="cart-empty-icon"><i class="fas fa-user-lock"></i></div>
                                <h3>Chưa đăng nhập</h3>
                                <p>Vui lòng đăng nhập để sử dụng giỏ hàng.</p>
                                <a href="/Auth/Login" class="ch-hero-btn-primary" style="display:inline-flex;gap:8px;align-items:center">
                                    Đăng nhập ngay <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    `;
                    return;
                }

                const res = await fetch(`http://localhost:5000/api/cart?user_id=${encodeURIComponent(userId)}`);
                const data = await res.json();

                if (data.success) {
                    renderCartPage(data.items || [], data.grandTotal || 0);
                } else {
                    cartSubText.textContent = 'Không thể tải giỏ hàng';
                    cartContent.innerHTML = `<div class="cart-card"><div class="cart-empty"><h3>Lỗi tải giỏ hàng</h3></div></div>`;
                }
            } catch (err) {
                console.error('LOAD CART ERROR:', err);
                const cartSubText = document.getElementById('cartSubText');
                const cartContent = document.getElementById('cartContent');
                cartSubText.textContent = 'Không thể tải giỏ hàng';
                cartContent.innerHTML = `<div class="cart-card"><div class="cart-empty"><h3>Lỗi kết nối BE</h3></div></div>`;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            loadCartPage();
        });
    </script>
}