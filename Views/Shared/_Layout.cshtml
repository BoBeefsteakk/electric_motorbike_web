<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — VinFast</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- TODO: Thay the logo VF bang logo chinh hang cua VinFast tai day -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- TOPBAR -->
    <div class="vf-topbar">
        <div class="vf-topbar-inner">
            <span><i class="fas fa-phone-alt"></i> Hotline: <strong>1800 599 961</strong></span>
            <span><i class="fas fa-clock"></i> Thứ Hai – Thứ Sáu: 08:00 – 21:00 &nbsp;|&nbsp; Thứ Bảy: 08:00 – 18:00</span>
            <span><i class="fas fa-map-marker-alt"></i> 10+ Showroom tại Hà Nội</span>
        </div>
    </div>

    <!-- NAVBAR - CarHut style -->
    <nav class="vf-navbar" id="navbar">
        <div class="vf-nav-inner">

            <!-- LOGO (TODO: thay bang logo chinh hang VinFast) -->
            <!-- Logo VinFast - dùng ảnh từ backend qua proxy -->
            <a href="/" class="vf-logo">
                <img src="/api-images/vinfast_home.png"
                     alt="VinFast Logo" class="vf-logo-img"
                     onerror="this.style.display='none';document.getElementById('vfLogoFallback').style.display='flex'" />
                <span id="vfLogoFallback" style="display:none;align-items:center;gap:8px">
                    <span class="vf-logo-icon">VF</span>
                    <span class="vf-logo-name">VinFast</span>
                </span>
            </a>

            <!-- NAV LINKS -->
            <ul class="vf-nav-links" id="navLinks">

                <li class="vf-nav-item has-drop">
                    <a href="/" class="vf-nav-link">
                        Trang Chủ <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown">
                        <a href="/"><i class="fas fa-home"></i> Trang Chủ</a>
                        <a href="/Vouchers"><i class="fas fa-ticket-alt"></i> Ưu Đãi Hiện Có</a>
                        <a href="#"><i class="fas fa-newspaper"></i> Tin Tức Mới Nhất</a>
                    </div>
                </li>

                <li class="vf-nav-item has-drop">
                    <a href="/Products" class="vf-nav-link">
                        Danh Mục <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown vf-dropdown-wide">
                        <div class="vf-dropdown-group">
                            <div class="vf-dropdown-label">Xe Máy Điện</div>
                            <a href="/Products?category=pho_thong"><i class="fas fa-motorcycle"></i> Xe Phổ Thông</a>
                            <a href="/Products?category=trung_cap"><i class="fas fa-bolt"></i> Xe Trung Cấp</a>
                            <a href="/Products?category=cao_cap"><i class="fas fa-star"></i> Xe Cao Cấp</a>
                        </div>
                        <div class="vf-dropdown-group">
                            <div class="vf-dropdown-label">Ô Tô</div>
                            <a href="/Cars?category=dong_co_dien"><i class="fas fa-charging-station"></i> Xe Điện</a>
                            <a href="/Cars?category=dong_co_xang"><i class="fas fa-gas-pump"></i> Xe Xăng</a>
                            <a href="/Cars?category=dong_xe_dich_vu"><i class="fas fa-shuttle-van"></i> Xe Dịch Vụ</a>
                        </div>
                        <div class="vf-dropdown-group">
                            <div class="vf-dropdown-label">Khác</div>
                            <a href="/Accessories"><i class="fas fa-tools"></i> Phụ Kiện</a>
                            <a href="/Vouchers"><i class="fas fa-tag"></i> Ưu Đãi</a>
                        </div>
                    </div>
                </li>

                <li class="vf-nav-item has-drop">
                    <a href="/Products" class="vf-nav-link">
                        Xe Máy <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown">
                        <a href="/Products?category=pho_thong"><i class="fas fa-motorcycle"></i> Xe Phổ Thông</a>
                        <a href="/Products?category=trung_cap"><i class="fas fa-bolt"></i> Xe Trung Cấp</a>
                        <a href="/Products?category=cao_cap"><i class="fas fa-star"></i> Xe Cao Cấp</a>
                        <a href="/Products"><i class="fas fa-list"></i> Tất Cả Xe Máy</a>
                    </div>
                </li>

                <li class="vf-nav-item has-drop">
                    <a href="/Cars" class="vf-nav-link">
                        Ô Tô <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown">
                        <a href="/Cars?category=dong_co_dien"><i class="fas fa-charging-station"></i> Xe Điện VF</a>
                        <a href="/Cars?category=dong_co_xang"><i class="fas fa-gas-pump"></i> Xe Xăng</a>
                        <a href="/Cars?category=dong_xe_dich_vu"><i class="fas fa-shuttle-van"></i> Xe Dịch Vụ</a>
                        <a href="/Cars"><i class="fas fa-list"></i> Tất Cả Ô Tô</a>
                    </div>
                </li>

                <li class="vf-nav-item">
                    <a href="/Stores" class="vf-nav-link">Showroom</a>
                </li>

                <li class="vf-nav-item has-drop">
                    <a href="#" class="vf-nav-link">
                        Về Chúng Tôi <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown">
                        <a href="#"><i class="fas fa-building"></i> Giới Thiệu VinFast</a>
                        <a href="#"><i class="fas fa-newspaper"></i> Tin Tức</a>
                        <a href="#"><i class="fas fa-question-circle"></i> Câu Hỏi Thường Gặp</a>
                        <a href="#"><i class="fas fa-headset"></i> Liên Hệ</a>
                    </div>
                </li>

                <li class="vf-nav-item">
                    <a href="#" class="vf-nav-link">Liên Hệ</a>
                </li>

            </ul>

            <!-- RIGHT ACTIONS -->
            <div class="vf-nav-actions">
                <a href="/Search" class="vf-nav-icon" title="Tìm kiếm">
                    <i class="fas fa-search"></i>
                </a>

                <a href="/Cart" class="vf-nav-icon" title="Giỏ hàng">
                    <i class="fas fa-shopping-bag"></i>
                    <span class="vf-cart-badge" id="cartBadge" style="display:none">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="vf-nav-item has-drop">
                        <a href="javascript:void(0)" class="vf-nav-link" style="display:flex;align-items:center;gap:6px">
                            <i class="fas fa-user-circle"></i> @User.Identity?.Name
                            <i class="fas fa-chevron-down"></i>
                        </a>

                        <div class="vf-dropdown vf-dropdown-right">
                            @if (User.IsInRole("admin"))
                            {
                                <a asp-controller="AdminProducts" asp-action="Index">
                                    <i class="fas fa-cog"></i> Quản lý sản phẩm
                                </a>
                            }

                            <a href="/Profile">
                                <i class="fas fa-user"></i> Hồ Sơ Của Tôi
                            </a>

                            <a href="/Auth/Logout">
                                <i class="fas fa-sign-out-alt"></i> Đăng Xuất
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Auth/Login" class="vf-signin-btn">
                        <i class="fas fa-user"></i> Đăng Nhập
                    </a>

                    <a href="/Auth/Register" class="vf-submit-btn">Đăng Ký</a>
                }

                <button class="vf-hamburger" id="hamburger">
                    <span></span><span></span><span></span>
                </button>
            </div>

        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="vf-footer">
        <div class="vf-footer-top">
            <div class="container">
                <div class="vf-footer-grid">
                    <div class="vf-footer-brand">
                        <!-- TODO: thay the bang logo chinh hang VinFast -->
                        <div class="vf-logo" style="margin-bottom:16px">
                            <span class="vf-logo-icon">VF</span>
                            <span class="vf-logo-name">VinFast</span>
                        </div>
                        <p>Hành trình điện hóa Việt Nam — Tiên phong vì một tương lai xanh và bền vững.</p>
                        <div class="vf-footer-social">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                            <a href="#"><i class="fab fa-tiktok"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Công Ty</h4>
                        <a href="#">Giới Thiệu</a>
                        <a href="#">Tin Tức</a>
                        <a href="#">Dịch Vụ</a>
                        <a href="#">Câu Hỏi Thường Gặp</a>
                        <a href="#">Liên Hệ</a>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Sản Phẩm</h4>
                        <a href="/Products">Xe Máy Điện</a>
                        <a href="/Cars">Ô Tô VinFast</a>
                        <a href="/Accessories">Phụ Kiện</a>
                        <a href="/Vouchers">Ưu Đãi</a>
                        <a href="/Stores">Showroom</a>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Loại Xe</h4>
                        <a href="/Products?category=pho_thong">Xe Phổ Thông</a>
                        <a href="/Products?category=trung_cap">Xe Trung Cấp</a>
                        <a href="/Products?category=cao_cap">Xe Cao Cấp</a>
                        <a href="/Cars?category=dong_co_dien">Ô Tô Điện</a>
                        <a href="/Cars?category=dong_co_xang">Ô Tô Xăng</a>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Giờ Làm Việc</h4>
                        <p class="vf-footer-hours">Thứ Hai – Thứ Sáu: 08:00 – 21:00</p>
                        <p class="vf-footer-hours">Thứ Bảy: 08:00 – 18:00</p>
                        <p class="vf-footer-hours">Chủ Nhật: Nghỉ</p>
                        <h4 style="margin-top:20px">Kết Nối</h4>
                        <div class="vf-footer-social" style="margin-top:10px">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                            <a href="#"><i class="fab fa-tiktok"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="vf-footer-bottom">
            <div class="container">
                <div class="vf-footer-bottom-inner">
                    <p>© 2025 VinFast LLC. Bảo lưu mọi quyền.</p>
                    <div class="vf-footer-bottom-links">
                        <a href="#">Điều Khoản & Điều Kiện</a>
                        <a href="#">Chính Sách Bảo Mật</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div class="toast" id="toast"></div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
