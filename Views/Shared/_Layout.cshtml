<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — VinFast</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- TODO: Thay the logo VF bang logo chinh hang cua VinFast tai day -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <!-- TOPBAR -->
    <div class="vf-topbar">
        <div class="vf-topbar-inner">
            <span><i class="fas fa-phone-alt"></i> Hotline: <strong>1800 599 961</strong></span>
            <span><i class="fas fa-clock"></i> Thứ Hai – Thứ Sáu: 08:00 – 21:00 &nbsp;|&nbsp; Thứ Bảy: 08:00 – 18:00</span>
            <span><i class="fas fa-map-marker-alt"></i> 10+ Showroom tại Hà Nội</span>
        </div>
    </div>

    <!-- NAVBAR - CarHut style -->
    <nav class="vf-navbar" id="navbar">
        <div class="vf-nav-inner">

            <!-- LOGO (TODO: thay bang logo chinh hang VinFast) -->
            <!-- Logo VinFast - dùng ảnh từ backend qua proxy -->
            <a href="/" class="vf-logo">
                <img src="/api-images/vinfast_home.png"
                     alt="VinFast Logo" class="vf-logo-img"
                     onerror="this.style.display='none';document.getElementById('vfLogoFallback').style.display='flex'" />
                <span id="vfLogoFallback" style="display:none;align-items:center;gap:8px">
                    <span class="vf-logo-icon">VF</span>
                    <span class="vf-logo-name">VinFast</span>
                </span>
            </a>

            <!-- NAV LINKS -->
            <ul class="vf-nav-links" id="navLinks">

                <li class="vf-nav-item has-drop">
                    <a href="/" class="vf-nav-link">
                        Trang Chủ <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown">
                        <a href="/"><i class="fas fa-home"></i> Trang Chủ</a>
                        <a href="/Vouchers"><i class="fas fa-ticket-alt"></i> Ưu Đãi Hiện Có</a>
                        <a href="#"><i class="fas fa-newspaper"></i> Tin Tức Mới Nhất</a>
                    </div>
                </li>

                <li class="vf-nav-item has-drop">
                    <a href="/Products" class="vf-nav-link">
                        Danh Mục <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown vf-dropdown-wide">
                        <div class="vf-dropdown-group">
                            <div class="vf-dropdown-label">Xe Máy Điện</div>
                            <a href="/Products?category=pho_thong"><i class="fas fa-motorcycle"></i> Xe Phổ Thông</a>
                            <a href="/Products?category=trung_cap"><i class="fas fa-bolt"></i> Xe Trung Cấp</a>
                            <a href="/Products?category=cao_cap"><i class="fas fa-star"></i> Xe Cao Cấp</a>
                        </div>
                        <div class="vf-dropdown-group">
                            <div class="vf-dropdown-label">Ô Tô</div>
                            <a href="/Cars?category=dong_co_dien"><i class="fas fa-charging-station"></i> Xe Điện</a>
                            <a href="/Cars?category=dong_co_xang"><i class="fas fa-gas-pump"></i> Xe Xăng</a>
                            <a href="/Cars?category=dong_xe_dich_vu"><i class="fas fa-shuttle-van"></i> Xe Dịch Vụ</a>
                        </div>
                        <div class="vf-dropdown-group">
                            <div class="vf-dropdown-label">Khác</div>
                            <a href="/Accessories"><i class="fas fa-tools"></i> Phụ Kiện</a>
                            <a href="/Vouchers"><i class="fas fa-tag"></i> Ưu Đãi</a>
                        </div>
                    </div>
                </li>

                <li class="vf-nav-item">
                    <a href="/Stores" class="vf-nav-link">Showroom</a>
                </li>

                <li class="vf-nav-item has-drop">
                    <a href="#" class="vf-nav-link">
                        Về Chúng Tôi <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="vf-dropdown">
                        <a href="#"><i class="fas fa-building"></i> Giới Thiệu VinFast</a>
                        <a href="#"><i class="fas fa-newspaper"></i> Tin Tức</a>
                        <a href="#"><i class="fas fa-question-circle"></i> Câu Hỏi Thường Gặp</a>
                        <a href="#"><i class="fas fa-headset"></i> Liên Hệ</a>
                    </div>
                </li>

                <li class="vf-nav-item">
                    <a href="#" class="vf-nav-link">Liên Hệ</a>
                </li>

            </ul>

            <!-- RIGHT ACTIONS -->
            <div class="vf-nav-actions">
                <div class="search-wrapper-dynamic">
                    <button type="button" id="searchIconBtn" class="vf-nav-icon" title="Tìm kiếm">
                        <i class="fas fa-search"></i>
                    </button>

                    <div id="dynamicSearchBar" class="search-bar-expandable">
                        <div class="search-input-box">
                            <i class="fas fa-search"></i>
                            <input type="text"
                                   id="globalSearchInput"
                                   placeholder="Tìm kiếm xe, ô tô, phụ kiện..."
                                   autocomplete="off" />
                            <button type="button" id="closeSearchBtn" aria-label="Đóng tìm kiếm">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>

                        <div id="globalSuggestionBox" class="dynamic-results"></div>
                    </div>
                </div>

                <a href="/Cart" class="vf-nav-icon" title="Giỏ hàng">
                    <i class="fas fa-shopping-bag"></i>
                    <span class="vf-cart-badge" id="cartBadge" style="display:none">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="vf-nav-item has-drop">
                        <a href="javascript:void(0)" class="vf-nav-link" style="display:flex;align-items:center;gap:6px">
                            <i class="fas fa-user-circle"></i> @User.Identity?.Name
                            <i class="fas fa-chevron-down"></i>
                        </a>

                        <div class="vf-dropdown vf-dropdown-right">
                            @if (User.IsInRole("admin"))
                            {
                                <a asp-controller="AdminProducts" asp-action="Index">
                                    <i class="fas fa-cog"></i> Quản lý sản phẩm
                                </a>
                            }
                            <a href="/Settings"><i class="fas fa-user"></i> Hồ Sơ Của Tôi</a>
                            <a href="/Auth/Logout"><i class="fas fa-sign-out-alt"></i> Đăng Xuất</a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Auth/Login" class="vf-signin-btn"><i class="fas fa-user"></i> Đăng Nhập</a>
                    <a href="/Auth/Register" class="vf-submit-btn">Đăng Ký</a>
                }

                <button class="vf-hamburger" id="hamburger">
                    <span></span><span></span><span></span>
                </button>
            </div>

        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="vf-footer">
        <div class="vf-footer-top">
            <div class="container">
                <div class="vf-footer-grid">
                    <div class="vf-footer-brand">
                        <!-- TODO: thay the bang logo chinh hang VinFast -->
                        <div class="vf-logo" style="margin-bottom:16px">
                            <span class="vf-logo-icon">VF</span>
                            <span class="vf-logo-name">VinFast</span>
                        </div>
                        <p>Hành trình điện hóa Việt Nam — Tiên phong vì một tương lai xanh và bền vững.</p>
                        <div class="vf-footer-social">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                            <a href="#"><i class="fab fa-tiktok"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Công Ty</h4>
                        <a href="#">Giới Thiệu</a>
                        <a href="#">Tin Tức</a>
                        <a href="#">Dịch Vụ</a>
                        <a href="#">Câu Hỏi Thường Gặp</a>
                        <a href="#">Liên Hệ</a>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Sản Phẩm</h4>
                        <a href="/Products">Xe Máy Điện</a>
                        <a href="/Cars">Ô Tô VinFast</a>
                        <a href="/Accessories">Phụ Kiện</a>
                        <a href="/Vouchers">Ưu Đãi</a>
                        <a href="/Stores">Showroom</a>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Loại Xe</h4>
                        <a href="/Products?category=pho_thong">Xe Phổ Thông</a>
                        <a href="/Products?category=trung_cap">Xe Trung Cấp</a>
                        <a href="/Products?category=cao_cap">Xe Cao Cấp</a>
                        <a href="/Cars?category=dong_co_dien">Ô Tô Điện</a>
                        <a href="/Cars?category=dong_co_xang">Ô Tô Xăng</a>
                    </div>
                    <div class="vf-footer-col">
                        <h4>Giờ Làm Việc</h4>
                        <p class="vf-footer-hours">Thứ Hai – Thứ Sáu: 08:00 – 21:00</p>
                        <p class="vf-footer-hours">Thứ Bảy: 08:00 – 18:00</p>
                        <p class="vf-footer-hours">Chủ Nhật: Nghỉ</p>
                        <h4 style="margin-top:20px">Kết Nối</h4>
                        <div class="vf-footer-social" style="margin-top:10px">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                            <a href="#"><i class="fab fa-tiktok"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="vf-footer-bottom">
            <div class="container">
                <div class="vf-footer-bottom-inner">
                    <p>© 2025 VinFast LLC. Bảo lưu mọi quyền.</p>
                    <div class="vf-footer-bottom-links">
                        <a href="#">Điều Khoản & Điều Kiện</a>
                        <a href="#">Chính Sách Bảo Mật</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div class="toast" id="toast"></div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (() => {
            const searchBtn = document.getElementById("searchIconBtn");
            const searchBar = document.getElementById("dynamicSearchBar");
            const searchInput = document.getElementById("globalSearchInput");
            const closeBtn = document.getElementById("closeSearchBtn");
            const suggestionBox = document.getElementById("globalSuggestionBox");

            if (!searchBtn || !searchBar || !searchInput || !closeBtn || !suggestionBox) return;

            let allItems = [];
            let loaded = false;

            const normalizeArray = (res) => {
                if (Array.isArray(res)) return res;
                if (Array.isArray(res?.data)) return res.data;
                return [];
            };

            const mapMotorbike = (i) => ({
                id: i.id,
                name: i.name,
                image: i.image,
                type: "motorbike",
                url: `/Products/Detail/${i.id}`
            });

            const mapCar = (i) => ({
                id: i.id,
                name: i.name,
                image: i.image,
                type: "car",
                url: `/Cars`
            });

            const mapAccessory = (i) => ({
                id: i.id,
                name: i.name,
                image: i.image,
                type: "accessory",
                url: `/Accessories`
            });

            const getImageUrl = (item) => {
                if (!item.image) return "/images/no-image.png";

                if (item.type === "motorbike" || item.type === "car") {
                    return `http://localhost:5000/images/${item.image}`;
                }

                return `http://localhost:5000/${item.image}`;
            };

            const renderSuggestions = (items, keyword) => {
                if (!keyword.trim()) {
                    suggestionBox.innerHTML = "";
                    suggestionBox.classList.remove("show");
                    return;
                }

                if (!items.length) {
                    suggestionBox.innerHTML = `
                        <div class="dynamic-empty">
                            Không tìm thấy kết quả cho "<strong>${keyword}</strong>"
                        </div>
                    `;
                    suggestionBox.classList.add("show");
                    return;
                }

                suggestionBox.innerHTML = items.slice(0, 8).map(item => `
                    <a href="${item.url}" class="dynamic-result-item">
                        <img src="${getImageUrl(item)}"
                             alt="${item.name}"
                             onerror="this.onerror=null;this.src='/images/no-image.png';" />
                        <div class="dynamic-result-info">
                            <div class="dynamic-result-name">${item.name}</div>
                            <div class="dynamic-result-type">
                                ${item.type === "motorbike" ? "Xe máy" :
                                  item.type === "car" ? "Ô tô" : "Phụ kiện"}
                            </div>
                        </div>
                    </a>
                `).join("");

                suggestionBox.classList.add("show");
            };

            const loadData = async () => {
                if (loaded) return;

                try {
                    const [motoRes, carRes, accRes] = await Promise.all([
                        fetch("http://localhost:5000/api/products").then(r => r.json()).catch(() => []),
                        fetch("http://localhost:5000/api/cars").then(r => r.json()).catch(() => []),
                        fetch("http://localhost:5000/api/accessories").then(r => r.json()).catch(() => [])
                    ]);

                    const motorbikes = normalizeArray(motoRes).map(mapMotorbike);
                    const cars = normalizeArray(carRes).map(mapCar);
                    const accessories = normalizeArray(accRes).map(mapAccessory);

                    allItems = [...motorbikes, ...cars, ...accessories];
                    loaded = true;
                } catch (err) {
                    console.error("Search load error:", err);
                }
            };

            const openSearch = async () => {
                searchBar.classList.add("open");
                await loadData();
                setTimeout(() => searchInput.focus(), 50);
            };

            const closeSearch = () => {
                searchBar.classList.remove("open");
                suggestionBox.classList.remove("show");
                suggestionBox.innerHTML = "";
                searchInput.value = "";
            };

            searchBtn.addEventListener("click", async (e) => {
                e.preventDefault();
                e.stopPropagation();

                if (searchBar.classList.contains("open")) {
                    closeSearch();
                } else {
                    await openSearch();
                }
            });

            closeBtn.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation();
                closeSearch();
            });

            searchInput.addEventListener("input", () => {
                const q = searchInput.value.trim().toLowerCase();

                const results = allItems.filter(item =>
                    (item.name || "").toLowerCase().includes(q)
                );

                renderSuggestions(results, searchInput.value);
            });

            searchInput.addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    const q = searchInput.value.trim();
                    if (!q) return;
                    window.location.href = `/Search?q=${encodeURIComponent(q)}`;
                }

                if (e.key === "Escape") {
                    closeSearch();
                }
            });

            document.addEventListener("click", (e) => {
                if (!searchBar.contains(e.target) && !searchBtn.contains(e.target)) {
                    suggestionBox.classList.remove("show");
                }
            });
        })();
    </script>
</body>
</html>
