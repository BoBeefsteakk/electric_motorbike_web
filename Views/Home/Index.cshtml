<!-- STORES -->
<section class="ch-section ch-section-alt">
    <div class="container">
        <h2 class="ch-section-title">Hệ Thống Showroom Hà Nội</h2>
        <p class="ch-section-sub">Ghé thăm và trải nghiệm xe trực tiếp tại cửa hàng gần bạn nhất</p>
        @if (!Model.Stores.Any())
        {
            <div class="pd-empty">
                <i class="fas fa-store"></i>
                <h3>Đang tải showroom...</h3>
                <p>Vui lòng đảm bảo Node.js backend đang chạy tại localhost:5000</p>
                <a href="/Stores" class="pd-btn-primary">Xem tất cả showroom</a>
            </div>
        }
        else
        {
            <div class="ch-store-grid">
                @foreach (var store in Model.Stores.Take(5))
                {
                    <div class="ch-store-card">
                        <div class="ch-store-img">
                            <img src="@store.ImageUrl" alt="@store.Name" loading="lazy"
                                 onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 4 3%22%3E%3Crect fill=%22%23f3f4f6%22 width=%224%22 height=%223%22/%3E%3C/svg%3E'" />
                        </div>
                        <div class="ch-store-body">
                            <div class="ch-store-name">@store.Name</div>
                            <div class="ch-store-rating">
                                <span class="stars">
                                    @{
                                        int rating = store.RatingInt;
                                    }
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < rating)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else
                                        {

                                            <i class="fas fa-star" style="opacity:.25"></i>
                                        }
                                    }
                                </span>
                                <span>@store.Rating</span>
                            </div>
                            <div class="ch-store-addr">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>@store.Address</span>
                            </div>
                        </div>
                        <a href="/Stores/Detail/@store.Id" class="ch-store-btn">Xem chi tiết</a>
                    </div>
                }
            </div>
        }
        <div class="ch-center">
            <a href="/Stores" class="ch-view-all">Xem tất cả showroom <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>

