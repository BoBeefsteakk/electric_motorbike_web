@model VinfastWeb.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang Chủ";
}

<!-- HERO -->
<section class="ch-hero">
    <!-- 3 slides full-screen, tự chuyển -->
    <div class="ch-hero-slides">
        <div class="ch-hero-slide active">
            <img src="http://localhost:5000/images/car/Vinfast VF7.jpg" alt="VinFast VF7" />
        </div>
        <div class="ch-hero-slide">
            <img src="http://localhost:5000/images/car/Vinfast VF6.jpg" alt="VinFast VF6" />
        </div>
        <div class="ch-hero-slide">
            <img src="http://localhost:5000/images/car/Vinfast VF8.jpg" alt="VinFast VF8" />
        </div>
    </div>

    <!-- Overlay tối -->
    <div class="ch-hero-overlay"></div>

    <!-- Nội dung text -->
    <div class="ch-hero-content">
        <p class="ch-hero-eyebrow">
            <span class="ch-hero-dot"></span>
            Tìm xe bán và cho thuê gần bạn
        </p>
        <h1 class="ch-hero-title">
            Tìm Chiếc Xe<br>
            <em>Mơ Ước</em> Của Bạn
        </h1>
        <p class="ch-hero-sub">Hàng trăm mẫu xe VinFast chính hãng · Giao tận nơi · Hỗ trợ trả góp</p>
        <div class="ch-hero-actions">
            <a href="/Products" class="ch-hero-btn-primary">Khám phá xe ngay <i class="fas fa-arrow-right"></i></a>
            <a href="/Stores" class="ch-hero-btn-ghost">Tìm showroom <i class="fas fa-map-marker-alt"></i></a>
        </div>
    </div>

    <!-- Dots điều hướng -->
    <div class="ch-hero-dots">
        <button class="ch-hero-dot-btn active" onclick="goSlide(0)"></button>
        <button class="ch-hero-dot-btn" onclick="goSlide(1)"></button>
        <button class="ch-hero-dot-btn" onclick="goSlide(2)"></button>
    </div>
</section>

<!-- BROWSE BY TYPE -->
<section class="ch-section ch-section-alt">
