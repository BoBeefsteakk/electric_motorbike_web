@section Scripts {
    <script>
        // Hero slideshow
        let currentSlide = 0;
        const slides = document.querySelectorAll('.ch-hero-slide');
        const dots = document.querySelectorAll('.ch-hero-dot-btn');

        function goSlide(n) {
            slides[currentSlide].classList.remove('active');
            dots[currentSlide].classList.remove('active');
            currentSlide = n;
            slides[currentSlide].classList.add('active');
            dots[currentSlide].classList.add('active');
        }

        function nextSlide() {
            goSlide((currentSlide + 1) % slides.length);
        }

        let slideTimer = setInterval(nextSlide, 5000);

        // Reset timer khi click dot
        document.querySelectorAll('.ch-hero-dot-btn').forEach((btn, i) => {
            btn.addEventListener('click', () => {
                clearInterval(slideTimer);
                slideTimer = setInterval(nextSlide, 5000);
            });
        });

        // Tab filter hoạt động thực sự
        function filterProducts(filter, el) {
          // Update tabs
          document.querySelectorAll('.ch-tab').forEach(t => t.classList.remove('active'));
          el.classList.add('active');

          // Ẩn tất cả grids
          document.querySelectorAll('[id^="grid-"]').forEach(g => g.style.display = 'none');

          // Hiện grid tương ứng
          const grid = document.getElementById('grid-' + filter);
          if (grid) grid.style.display = 'grid';

          // Cập nhật link "Xem tất cả"
          const link = document.getElementById('viewAllLink');
          if (filter === 'o_to') {
            link.href = '/Cars';
            link.innerHTML = 'Xem tất cả ô tô <i class="fas fa-arrow-right"></i>';
            document.getElementById('grid-o_to').style.display = 'grid';
          } else {
            link.href = '/Products?category=' + filter;
            const labels = { pho_thong: 'xe phổ thông', trung_cap: 'xe trung cấp', cao_cap: 'xe cao cấp' };
            link.innerHTML = 'Xem tất cả ' + (labels[filter] || 'xe') + ' <i class="fas fa-arrow-right"></i>';
          }
        }

        // Search bar
        function doSearch() {
          const type = document.getElementById('searchType').value;
          const cat  = document.getElementById('searchCategory').value;
          if (type === 'car') { window.location = '/Cars'; return; }
          if (type === 'accessory') { window.location = '/Accessories'; return; }
          window.location = cat ? '/Products?category=' + cat : '/Products';
        }
    </script>
}
