@model VinfastWeb.ViewModels.ProductsViewModel
@{
    ViewData["Title"] = Model.CategoryLabel;
}

<!-- PAGE HEADER -->
<div class="pd-header">
    <div class="container">
        <nav class="pd-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="fas fa-chevron-right"></i>
            <a href="/Products">Xe Máy Điện</a>
            @if (!string.IsNullOrEmpty(Model.Category))
            {
                <i class="fas fa-chevron-right"></i>
                <span>@Model.CategoryLabel</span>
            }
        </nav>
        <h1 class="pd-header-title">@Model.CategoryLabel</h1>
        <p class="pd-header-sub">@Model.Motorbikes.Count mẫu xe đang có sẵn</p>
    </div>
</div>

<!-- FILTER TABS -->
<div class="pd-filter-bar">
    <div class="container">
        <div class="pd-filter-tabs">
            <a href="/Products" class="pd-ftab @(string.IsNullOrEmpty(Model.Category) ? "active" : "")">
                Tất Cả
            </a>
            <a href="/Products?category=pho_thong" class="pd-ftab @(Model.Category == "pho_thong" ? "active" : "")">
                <i class="fas fa-motorcycle"></i> Phổ Thông
            </a>
            <a href="/Products?category=trung_cap" class="pd-ftab @(Model.Category == "trung_cap" ? "active" : "")">
                <i class="fas fa-bolt"></i> Trung Cấp
            </a>
            <a href="/Products?category=cao_cap" class="pd-ftab @(Model.Category == "cao_cap" ? "active" : "")">
                <i class="fas fa-star"></i> Cao Cấp
            </a>
        </div>
        <div class="pd-sort">
            <select class="pd-sort-select" onchange="sortProducts(this.value)">
                <option value="">Sắp xếp theo</option>
                <option value="price-asc">Giá: Thấp → Cao</option>
                <option value="price-desc">Giá: Cao → Thấp</option>
                <option value="name">Tên A → Z</option>
            </select>
        </div>
    </div>
</div>

<!-- PRODUCT GRID -->
<section class="pd-section">
    <div class="container">
        @if (!Model.Motorbikes.Any())
        {
            <div class="pd-empty">
                <i class="fas fa-motorcycle"></i>
                <h3>Không có xe nào</h3>
                <p>Vui lòng chọn danh mục khác hoặc quay lại sau.</p>
                <a href="/Products" class="pd-btn-primary">Xem tất cả xe</a>
            </div>
        }
        else
        {
            <div class="pd-grid" id="productGrid">
                @foreach (var item in Model.Motorbikes)
                {
                    <a href="/Products/Detail/@item.Id" class="pd-card" data-price="@item.Price" data-name="@item.Name">
                        <div class="pd-card-img">
                            <img src="@item.ImageUrl" alt="@item.Name" loading="lazy"
                                 onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 4 3%22%3E%3Crect fill=%22%23f3f4f6%22 width=%224%22 height=%223%22/%3E%3C/svg%3E'" />
                            <div class="pd-card-badge">
                                @(item.Category == "cao_cap" ? "Cao Cấp" : item.Category == "trung_cap" ? "Trung Cấp" : "Phổ Thông")
                            </div>
                            <div class="pd-card-wish" onclick="event.preventDefault();event.stopPropagation()">
                                <i class="far fa-heart"></i>
                            </div>
                        </div>
                        <div class="pd-card-body">
                            <div class="pd-card-cat">VinFast · Xe Máy Điện</div>
                            <div class="pd-card-name">@item.Name</div>
                            <div class="pd-card-specs">
                                <span><i class="fas fa-bolt"></i> Pin LFP</span>
                                <span><i class="fas fa-tachometer-alt"></i> Thông minh</span>
                                <span><i class="fas fa-shield-alt"></i> BH 3 năm</span>
                            </div>
                            <div class="pd-card-footer">
                                <div class="pd-card-price">@item.FormattedPrice</div>
                                <div class="pd-card-btn">Xem chi tiết <i class="fas fa-arrow-right"></i></div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        function sortProducts(val) {
          const grid = document.getElementById('productGrid');
          if (!grid) return;
          const cards = Array.from(grid.querySelectorAll('.pd-card'));
          cards.sort((a, b) => {
            if (val === 'price-asc')  return +a.dataset.price - +b.dataset.price;
            if (val === 'price-desc') return +b.dataset.price - +a.dataset.price;
            if (val === 'name')       return a.dataset.name.localeCompare(b.dataset.name);
            return 0;
          });
          cards.forEach(c => grid.appendChild(c));
        }
    </script>
}
