<script>
    document.addEventListener("DOMContentLoaded", function () {

        // ── Menu navigation ──────────────────────────────────────
        const menus    = document.querySelectorAll(".setting-menu");
        const sections = document.querySelectorAll(".setting-section");

        menus.forEach(menu => {
            menu.addEventListener("click", function () {
                const target = this.getAttribute("data-section");
                menus.forEach(m => m.classList.remove("active"));
                this.classList.add("active");
                sections.forEach(s => s.style.display = "none");
                const el = document.getElementById("section-" + target);
                if (el) el.style.display = "block";
            });
        });

        // ── Avatar upload ─────────────────────────────────────────
        const avatarInput   = document.getElementById("avatarFile");
        const avatarPreview = document.getElementById("avatarPreview");
        const sidebarAvatar = document.getElementById("sidebarAvatar");
        const avatarUri     = document.getElementById("AvatarUri");

        if (avatarInput) {
            avatarInput.addEventListener("change", function (e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function (evt) {
                    avatarPreview.src  = evt.target.result;
                    sidebarAvatar.src  = evt.target.result;
                    avatarUri.value    = evt.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        // ── Profile form toast on submit ──────────────────────────
        const profileForm = document.getElementById("profileForm");
        if (profileForm) {
            profileForm.addEventListener("submit", function () {
                showToast("Lưu thông tin thành công!");
            });
        }

        // ── Full name mirrors to sidebar ──────────────────────────
        const fullNameInput = document.getElementById("FullNameInput");
        if (fullNameInput) {
            const sidebarName = document.querySelector("#sidebarAvatar + div div:first-child");
            fullNameInput.addEventListener("input", function () {
                if (sidebarName) sidebarName.textContent = this.value;
            });
        }
    });

    // ── Gender selection ──────────────────────────────────────────
    function selectGender(el) {
        document.querySelectorAll(".gender-btn").forEach(b => b.classList.remove("selected"));
        el.classList.add("selected");
        document.getElementById("GenderHidden").value = el.getAttribute("data-value");
    }

    // ── Order filter tabs ─────────────────────────────────────────
    function filterOrders(status, btn) {
        document.querySelectorAll(".order-tab").forEach(t => {
            t.style.background  = "#fff";
            t.style.color       = "#555";
            t.style.border      = "2px solid #e5e7eb";
        });
        btn.style.background = "#1f2a56";
        btn.style.color      = "#fff";
        btn.style.border     = "2px solid #1f2a56";

        document.querySelectorAll(".order-item").forEach(item => {
            if (status === "all" || item.getAttribute("data-status") === status) {
                item.style.display = "block";
            } else {
                item.style.display = "none";
            }
        });
    }

    // ── Toast helper ──────────────────────────────────────────────
    function showToast(msg) {
        const toast = document.getElementById("toast");
        document.getElementById("toastMsg").textContent = msg || "Lưu thành công!";
        toast.style.display = "flex";
        toast.style.animation = "slideIn .3s ease";
        clearTimeout(toast._timer);
        toast._timer = setTimeout(() => {
            toast.style.animation = "slideOut .3s ease forwards";
            setTimeout(() => { toast.style.display = "none"; }, 300);
        }, 2800);
    }
</script>
